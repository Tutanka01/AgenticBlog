# ── LLM — OpenRouter ──────────────────────────────────────────────────────────
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=mistralai/mistral-7b-instruct
DEBATE_MODEL=mistralai/mistral-7b-instruct
LLM_TEMPERATURE=0.3

# Headers OpenRouter (attribution, optionnels mais recommandés)
OPENROUTER_SITE_URL=https://github.com/AgenticBlog
OPENROUTER_APP_NAME=AgenticBlog

# ── Pour Ollama en local ───────────────────────────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=mistral

# ── Pipeline ──────────────────────────────────────────────────────────────────
FILTER_THRESHOLD=6
MAX_ARTICLES_TO_FETCH=40
TOP_N_FILTERED=5
MAX_CRITIQUE_ITERATIONS=3

# ── Chemins ───────────────────────────────────────────────────────────────────
CHECKPOINT_DB=memory/checkpoints.sqlite
OUTPUT_DIR=./output
PROMPTS_DIR=./prompts

# ── Flux RSS (séparés par des virgules, sans espaces) ─────────────────────────
RSS_FEEDS=https://hnrss.org/frontpage,https://lwn.net/headlines/rss,https://feeds.feedburner.com/TheHackersNews,https://www.reddit.com/r/kubernetes/.rss,https://www.reddit.com/r/devops/.rss

# ── Topics d'intérêt (séparés par des virgules) ───────────────────────────────
INTEREST_TOPICS=kubernetes,devops,linux,docker,CI/CD,GitOps,cloud,cybersecurity,AI agents,LLM,infrastructure,Maroc,Morocco,Afrique,tech africa
